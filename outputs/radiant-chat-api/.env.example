# ─── Radiant Chat API — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Google AI ───────────────────────────────────────────────────────────────
# Your Google AI API key — get it free at https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ─── CORS ────────────────────────────────────────────────────────────────────
# Your production frontend URL (used for CORS allowlist)
# Example: https://radiant-digital.ai
FRONTEND_URL=https://your-site.com

# ─── Server ──────────────────────────────────────────────────────────────────
# Port (your hosting provider may set this automatically)
PORT=3001

# ─── Admin Panel ─────────────────────────────────────────────────────────────
# Secret URL path for the admin panel — choose something hard to guess
# Example: /admin-a8f2k3p9  or  /manage-r7x2q1
# Do NOT use /admin — pick something unpredictable
ADMIN_PATH=/admin-changeme

# Admin login credentials
ADMIN_USERNAME=admin

# Generate a bcrypt hash of your password by running:
#   npm run hash-password yourpasswordhere
# Then paste the output hash below (starts with $2b$)
ADMIN_PASSWORD_HASH=$2b$12$replacethiswithyourrealbcrypthash

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Long random secret for signing JWT tokens
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-secret-at-least-64-chars
