# ─── Radiant Chat API — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Your Google AI API key — get it free at https://aistudio.google.com/apikey
# Model: gemma-4-31b-it (Gemma 4 31B Dense — #3 open model globally)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Your Vercel frontend URL (used for CORS)
# Example: https://your-app.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app

# Port (Railway sets this automatically — leave as 3001 for local dev)
PORT=3001
