# Server
PORT=3001
NODE_ENV=production

# MySQL (Liquid Web)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=radiant_cms
DB_USER=radiant_user
DB_PASSWORD=your_db_password_here

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=24h

# Admin seed (first run only — delete after seeding)
ADMIN_EMAIL=admin@radiant.digital
ADMIN_PASSWORD=change_this_password

# Frontend URL (for CORS)
FRONTEND_URL=https://yourdomain.com
